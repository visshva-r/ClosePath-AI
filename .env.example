# Optional. ClosePath works fully without any API key.
# Gemini is ONLY called when you click "Enhance with Gemini" in the UI.

# Google AI Studio: https://aistudio.google.com/apikey
# Key format is usually AIza...
GEMINI_API_KEY=
# Prefer a current Flash model. The app also auto-discovers models via ListModels.
GEMINI_MODEL=gemini-2.5-flash

# Optional fallback (also click-only via the same button)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
